TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
CMC_API_KEY=your_coinmarketcap_api_key_here

# One or more targets (comma-separated). Use /chatid inside a chat to get the value.
# Plain group/channel:   -1001234567890
# Specific topic:        -1001234567890:123
# Multiple targets:      -1001234567890:123,-1009876543210
TARGET_CHAT_ID=

# Spike alert — fires when CMC's rolling 1h change exceeds the threshold
# SPIKE_THRESHOLD_PCT: % move that triggers the alert (default: 10)
# SPIKE_COOLDOWN_HOURS: hours to wait before the next spike alert (default: 2)
SPIKE_THRESHOLD_PCT=10
SPIKE_COOLDOWN_HOURS=2

# Hourly swing alert — compares bot's own captured price snapshots each hour
# HOURLY_SWING_PCT: % move between hourly ticks that triggers the tag (default: 10)
# HOURLY_SWING_TAG: who to tag — @username or space-separated @user1 @user2
HOURLY_SWING_PCT=10
HOURLY_SWING_TAG=
