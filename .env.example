TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
CMC_API_KEY=your_coinmarketcap_api_key_here
# Chat/group/channel the bot always posts to (find it with /chatid command)
# Plain group:       TARGET_CHAT_ID=-1001234567890
# Specific topic:    TARGET_CHAT_ID=-1001234567890:123
# Group IDs are negative numbers; topic ID is shown by /chatid inside the topic
TARGET_CHAT_ID=
