# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=7123456789:AAF...your_token...

# Target Chat IDs (comma-separated, optional :thread_id for topics)
# Example: TARGET_CHAT_ID=-1001234567890:42,-1009876543210
TARGET_CHAT_ID=-1001234567890

# Optional Crypto API Keys (CoinMarketCap API Key)
# If omitted, CoinGecko & Yahoo Finance will be used as free fallbacks
CMC_API_KEY=your_coinmarketcap_api_key

# Drastic Price Movement Alerts Threshold (%)
SPIKE_THRESHOLD_PCT=5.0
SPIKE_COOLDOWN_HOURS=2.0

# User / Topic tag on alerts (e.g. @investor_team)
HOURLY_SWING_TAG=@username

# AI Stock & Crypto Research Provider (gemini | openai | anthropic)
AI_PROVIDER=gemini
AI_API_KEY=your_ai_api_key
# AI_MODEL=gemini-2.5-flash

# Database path (default: investor_bot.db)
DATABASE_PATH=investor_bot.db
