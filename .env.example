TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
CMC_API_KEY=your_coinmarketcap_api_key_here

# One or more targets (comma-separated). Use /chatid inside a chat to get the value.
# Plain group/channel:   -1001234567890
# Specific topic:        -1001234567890:123
# Multiple targets:      -1001234567890:123,-1009876543210
TARGET_CHAT_ID=

# Hourly swing alert — tags someone if price moves more than X% between hourly ticks
# HOURLY_SWING_PCT: threshold percentage (default: 10)
# HOURLY_SWING_TAG: who to tag — @username or comma-separated @user1,@user2
HOURLY_SWING_PCT=10
HOURLY_SWING_TAG=
